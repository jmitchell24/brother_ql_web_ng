<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/static/css/bootstrap.min.css">
    <link rel="stylesheet" href="/static/css/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/static/css/custom.css">
    <title>{{ website['HTML_TITLE'] }} | Brother QL</title>
  </head>
  <body>
    <nav class="navbar bg-body-tertiary border-bottom">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/">
          <i class="bi bi-printer me-2"></i>{{ website['PAGE_TITLE'] }}
        </a>
        <button id="themeToggle" class="btn btn-sm btn-outline-secondary" title="Toggle dark/light mode">
          <i class="bi bi-moon-fill" id="themeIcon"></i>
        </button>
      </div>
    </nav>
    <div class="container py-4">
      {% block content %}{% endblock %}
    </div>

    <script src="/static/js/bootstrap.bundle.min.js"></script>
    <script src="/static/js/jquery.min.js"></script>
    <script>
      const html = document.documentElement;
      const stored = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      html.setAttribute('data-bs-theme', stored);
      updateThemeIcon(stored);

      document.getElementById('themeToggle').addEventListener('click', () => {
        const next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-bs-theme', next);
        localStorage.setItem('theme', next);
        updateThemeIcon(next);
        applyClipartTheme(next);
      });

      function updateThemeIcon(theme) {
        document.getElementById('themeIcon').className = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
      }

      function applyClipartTheme(theme) {
        const f = theme === 'dark' ? 'invert(1)' : '';
        document.querySelectorAll('.clipart-item img').forEach(function(img) { img.style.filter = f; });
      }
    </script>
    <script type="text/javascript">
      {% block javascript %}{% endblock %}
    </script>
  </body>
</html>
