{% extends "base.jinja2" %}

{% block content %}
<div class="row g-4">

  {# Left column: text input, preview + print #}
  <div class="col-md-6">
    <label for="labelText" class="form-label">Label Text</label>
    <textarea rows="4" id="labelText" class="form-control mb-3" onchange="preview()" oninput="preview()"></textarea>
    <div class="mb-2">
      <img id="previewImg" class="img-fluid rounded border" style="max-height: 200px; width: auto;"/>
    </div>
    <p class="text-body-secondary small mb-3">
      Printed size: <span id="labelWidth">?</span> cm &times; <span id="labelHeight">?</span> cm
    </p>
    <button id="printButton" type="button" class="btn btn-primary mb-2" onclick="print()">
      <i class="bi bi-printer me-2"></i>Print
    </button>
    <div id="printResultPanel" class="small py-1" style="display:none"></div>
  </div>

  {# Right column: settings #}
  <div class="col-md-6">
    <ul class="nav nav-tabs mb-3" id="settingsTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tab-settings-tab" data-bs-toggle="tab" data-bs-target="#tab-settings" type="button" role="tab" title="Settings"><i class="bi bi-sliders"></i></button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-image-tab" data-bs-toggle="tab" data-bs-target="#tab-image" type="button" role="tab" title="Clip Art"><i class="bi bi-image"></i></button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-configs-tab" data-bs-toggle="tab" data-bs-target="#tab-configs" type="button" role="tab" title="Saved Configs"><i class="bi bi-bookmark"></i></button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="tab-printer-tab" data-bs-toggle="tab" data-bs-target="#tab-printer" type="button" role="tab" title="Printer"><i class="bi bi-printer"></i></button>
      </li>
    </ul>
    <div class="tab-content" id="settingsTabContent">

      <div class="tab-pane fade show active" id="tab-settings" role="tabpanel">
        <label for="labelSize" class="form-label">Label Size</label>
        <select class="form-select" id="labelSize" onchange="preview()">
          {% for label_size in label_sizes %}
            <option value="{{ label_size[0] }}" {% if label['DEFAULT_SIZE'] == label_size[0] %}selected{% endif %}>{{ label_size[1] }}</option>
          {% endfor %}
        </select>
        <hr class="my-3">
        <label for="fontFamily" class="form-label">Font Family</label>
        <select class="form-select" id="fontFamily" onchange="preview()">
          {% for font_family_name in font_family_names %}
            {% for font_style in fonts[font_family_name].keys() %}
              <option {% if label['DEFAULT_FONTS']['style'] == font_style and label['DEFAULT_FONTS']['family'] == font_family_name %}selected{% endif %}>{{ font_family_name }} ({{ font_style }})</option>
            {% endfor %}
          {% endfor %}
        </select>
        <label for="fontSize" class="form-label mt-3">Font Size</label>
        <input id="fontSize" class="form-control" type="number" min="1" value="{{ label['DEFAULT_FONT_SIZE'] }}" onchange="preview()" required>
        <label class="form-label mt-3">Alignment</label>
        <div class="btn-group d-flex" role="group">
          <input type="radio" class="btn-check" name="fontAlign" id="alignLeft" value="left" onchange="preview()">
          <label class="btn btn-outline-secondary w-100" for="alignLeft"><i class="bi bi-text-left"></i></label>
          <input type="radio" class="btn-check" name="fontAlign" id="alignCenter" value="center" onchange="preview()" checked>
          <label class="btn btn-outline-secondary w-100" for="alignCenter"><i class="bi bi-text-center"></i></label>
          <input type="radio" class="btn-check" name="fontAlign" id="alignRight" value="right" onchange="preview()">
          <label class="btn btn-outline-secondary w-100" for="alignRight"><i class="bi bi-text-right"></i></label>
        </div>
        <hr class="my-3">
        <div class="row g-2">
          <div class="col-6">
            <label for="marginTop" class="form-label">Margin Top</label>
            <div class="input-group marginsTopBottom">
              <input id="marginTop" class="form-control" type="number" min="0" max="200" value="24" onchange="preview()" required>
              <span class="input-group-text">%</span>
            </div>
          </div>
          <div class="col-6">
            <label for="marginBottom" class="form-label">Margin Bottom</label>
            <div class="input-group marginsTopBottom">
              <input id="marginBottom" class="form-control" type="number" min="0" max="200" value="45" onchange="preview()" required>
              <span class="input-group-text">%</span>
            </div>
          </div>
          <div class="col-6">
            <label for="marginLeft" class="form-label">Margin Left</label>
            <div class="input-group marginsLeftRight">
              <input id="marginLeft" class="form-control" type="number" min="0" max="200" value="35" onchange="preview()" required>
              <span class="input-group-text">%</span>
            </div>
          </div>
          <div class="col-6">
            <label for="marginRight" class="form-label">Margin Right</label>
            <div class="input-group marginsLeftRight">
              <input id="marginRight" class="form-control" type="number" min="0" max="200" value="35" onchange="preview()" required>
              <span class="input-group-text">%</span>
            </div>
          </div>
          <div class="col-12 mt-2">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="borderEnabled" onchange="onBorderToggle()">
              <label class="form-check-label" for="borderEnabled">Add border</label>
            </div>
          </div>
          <div class="col-12" id="borderWidthRow" style="display:none">
            <label for="borderWidth" class="form-label">Border width</label>
            <div class="input-group">
              <input id="borderWidth" class="form-control" type="number" min="1" max="20" value="3" onchange="preview()" required>
              <span class="input-group-text">px</span>
            </div>
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="tab-image" role="tabpanel">
        <div id="clipartPanel">
          <input type="text" class="form-control form-control-sm mb-2" id="clipartSearch"
                 placeholder="Search icons..." oninput="filterClipart()">
          <div id="clipartGrid" style="display:flex;flex-wrap:wrap;gap:4px;max-height:210px;overflow-y:auto;overflow-x:hidden"></div>
        </div>

        <div class="align-items-center gap-2 mt-3" id="imageClearBtn" style="display:none">
          <button class="btn btn-sm btn-outline-secondary" type="button" onclick="clearImage()">
            <img src="https://cdn.jsdelivr.net/npm/@phosphor-icons/core@2/assets/regular/eraser.svg" width="15" height="15" class="me-1" style="vertical-align:text-bottom">Clear
          </button>
          <span id="clipartSelectedName" class="small fst-italic text-body-secondary text-truncate"></span>
        </div>
        <div id="imageOptions" style="display:none">
          <label class="form-label mt-3">Image position</label>
          <div class="btn-group d-flex" role="group">
            <input type="radio" class="btn-check" name="imageAlign" id="imageAlignLeft" value="left" checked onchange="preview()">
            <label class="btn btn-outline-secondary w-100" for="imageAlignLeft">Left of text</label>
            <input type="radio" class="btn-check" name="imageAlign" id="imageAlignRight" value="right" onchange="preview()">
            <label class="btn btn-outline-secondary w-100" for="imageAlignRight">Right of text</label>
          </div>
          <label for="imageGap" class="form-label mt-3">Gap between image and text</label>
          <div class="input-group">
            <input id="imageGap" class="form-control" type="number" min="0" max="200" value="20" onchange="preview()">
            <span class="input-group-text">px</span>
          </div>
        </div>
      </div>


      <div class="tab-pane fade" id="tab-configs" role="tabpanel">
        <div class="d-flex gap-2 mb-2">
          <input id="configName" class="form-control form-control-sm" type="text" placeholder="Config name…" maxlength="80">
          <button class="btn btn-sm btn-outline-danger flex-shrink-0" title="Delete all" onclick="deleteAllConfigs()">
            <i class="bi bi-trash"></i>
          </button>
        </div>
        <button class="btn btn-sm btn-primary w-100 mb-3" type="button" onclick="saveConfig()">
          <i class="bi bi-plus-circle me-1"></i>Create new
        </button>
        <div id="configList" class="list-group list-group-flush" style="max-height: 60vh; overflow-y: auto;">
          <div class="list-group-item text-body-secondary small px-0">Loading…</div>
        </div>
      </div>

      <div class="tab-pane fade" id="tab-printer" role="tabpanel">
        <div class="mb-2">
          <span id="printerStatusBadge" class="badge text-bg-secondary">—</span>
        </div>
        <table class="table table-sm table-borderless mb-3 small">
          <tbody id="printerInfoTable">
            <tr><td class="text-body-secondary">Model</td><td id="pi-model">—</td></tr>
            <tr><td class="text-body-secondary">Connection</td><td id="pi-printer" class="text-break font-monospace" style="font-size:0.75em"></td></tr>
            <tr><td class="text-body-secondary">Default label</td><td id="pi-label">—</td></tr>
            <tr id="pi-row-serial" style="display:none"><td class="text-body-secondary">Serial</td><td id="pi-serial" class="font-monospace" style="font-size:0.75em"></td></tr>
            <tr id="pi-row-usb" style="display:none"><td class="text-body-secondary">USB</td><td id="pi-usb"></td></tr>
            <tr id="pi-row-speed" style="display:none"><td class="text-body-secondary">Speed</td><td id="pi-speed"></td></tr>
          </tbody>
        </table>
        <button class="btn btn-outline-secondary w-100" onclick="updatePrinterInfo()">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
      </div>

    </div>
  </div>


</div>

{% endblock %}

{% block javascript %}
var cachedImageData = null;
var cachedClipartIcon = null;

function clearImage() {
  cachedImageData = null;
  cachedClipartIcon = null;
  $('#imageOptions, #imageClearBtn').hide();
  preview();
}

function clearClipart() { clearImage(); }

// --- Clip Art ---

var CLIPART_CDN = '/static/clipart/';

function buildClipartGrid() {
  var $grid = $('#clipartGrid').empty();
  $grid.html('<span class="text-body-secondary small p-1">Loading icons\u2026</span>');
  $.getJSON('/api/clipart', function(names) {
    $grid.empty();
    names.forEach(function(name) {
      var $btn = $('<button type="button" class="btn btn-outline-secondary p-0 clipart-item">')
        .attr('title', name)
        .css({width:'40px', height:'40px', display:'inline-flex', alignItems:'center', justifyContent:'center'})
        .on('click', function() { selectClipart(name); });
      $('<img width="22" height="22" style="pointer-events:none" alt="' + name + '">')
        .attr('src', CLIPART_CDN + name + '.svg')
        .appendTo($btn);
      $grid.append($btn);
    });
  }).fail(function() {
    $grid.html('<span class="text-danger small p-1">Failed to load icon list.</span>');
  });
}

function filterClipart() {
  var q = ($('#clipartSearch').val() || '').toLowerCase();
  $('#clipartGrid .clipart-item').each(function() {
    $(this).toggle(!q || $(this).attr('title').includes(q));
  });
}


function selectClipart(name) {
  fetch(CLIPART_CDN + name + '.svg')
    .then(function(r) { return r.text(); })
    .then(function(svgText) {
      var blob = new Blob([svgText], {type: 'image/svg+xml'});
      var objUrl = URL.createObjectURL(blob);
      var canvas = document.createElement('canvas');
      canvas.width = 256; canvas.height = 256;
      var img = new Image();
      img.onload = function() {
        canvas.getContext('2d').drawImage(img, 0, 0, 256, 256);
        URL.revokeObjectURL(objUrl);
        cachedImageData = canvas.toDataURL('image/png').split(',')[1];
        cachedClipartIcon = name;
        $('#clipartSelectedName').text(name);
        $('#imageOptions').show();
        $('#imageClearBtn').css('display', 'flex');
        preview();
      };
      img.src = objUrl;
    });
}

function formData() {
  var text = $('#labelText').val();
  if (text == '') text = ' ';
  var borderOn = $('#borderEnabled').is(':checked');
  return {
    text:          text,
    font_family:   $('#fontFamily option:selected').text(),
    font_size:     $('#fontSize').val(),
    label_size:    $('#labelSize option:selected').val(),
    align:         $('input[name=fontAlign]:checked').val(),
    orientation:   'standard',
    margin_top:    $('#marginTop').val(),
    margin_bottom: $('#marginBottom').val(),
    margin_left:   $('#marginLeft').val(),
    margin_right:  $('#marginRight').val(),
    border:        borderOn ? 'true' : 'false',
    border_width:  borderOn ? $('#borderWidth').val() : 0,
    image_data:    cachedImageData || '',
    image_bw:      'true',
    image_align:   $('input[name=imageAlign]:checked').val() || 'left',
    image_gap:     $('#imageGap').val()
  };
}

function onBorderToggle() {
  var on = $('#borderEnabled').is(':checked');
  $('#borderWidthRow').toggle(on);
  preview();
}

function preview() {
  $('.marginsLeftRight').prop('disabled', true);

  $.ajax({
    type:        'POST',
    url:         '/api/preview/text?return_format=base64',
    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
    data:        formData(),
    success: function(data) {
      $('#previewImg').attr('src', 'data:image/png;base64,' + data);
      var img = $('#previewImg')[0];
      img.onload = function() {
        $('#labelWidth').text((img.naturalWidth  / 300 * 2.54).toFixed(1));
        $('#labelHeight').text((img.naturalHeight / 300 * 2.54).toFixed(1));
      };
    }
  });
}

function setPrintResult(data) {
  var msg, cls, icon;
  if (data['success']) {
    cls  = 'text-success';
    icon = 'bi-check-circle-fill';
    msg  = 'Printed successfully.';
  } else {
    cls  = 'text-warning';
    icon = 'bi-exclamation-triangle-fill';
    msg  = 'Failed: ' + (data['error'] || data['message'] || 'unknown error');
  }
  var panel = $('#printResultPanel');
  panel.html('<i class="bi ' + icon + ' me-1 ' + cls + '"></i><span>' + msg + '</span>').show();
  $('#printButton').prop('disabled', false);
}

function print() {
  $('#printButton').prop('disabled', true);
  $('#printResultPanel').html('<div class="spinner-border spinner-border-sm me-2" role="status"></div><span class="text-body-secondary">Sending to printer...</span>').show();
  $.ajax({
    type:     'POST',
    dataType: 'json',
    data:     formData(),
    url:      '/api/print/text',
    success:  setPrintResult,
    error:    function() { setPrintResult({success: false, error: 'Server error'}); }
  });
}

function updatePrinterInfo() {
  $.getJSON('/api/printer/info', function(d) {
    $('#pi-model').text(d.model || '—');
    $('#pi-printer').text(d.printer || '—');
    $('#pi-label').text(d.label || '—');

    var badge = $('#printerStatusBadge');
    if (d.status === 'online') {
      badge.text('Online').removeClass().addClass('badge text-bg-success');
    } else if (d.status === 'offline') {
      badge.text('Offline').removeClass().addClass('badge text-bg-danger');
    } else {
      badge.text(d.status || '—').removeClass().addClass('badge text-bg-secondary');
    }

    if (d.serial) {
      $('#pi-serial').text(d.serial);
      $('#pi-row-serial').show();
    }
    if (d.usb_bus !== undefined) {
      $('#pi-usb').text('Bus ' + d.usb_bus + ', Address ' + d.usb_address);
      $('#pi-row-usb').show();
    }
    if (d.usb_speed) {
      $('#pi-speed').text(d.usb_speed);
      $('#pi-row-speed').show();
    }
  });
}

updatePrinterInfo();
setInterval(updatePrinterInfo, 5000);
buildClipartGrid();
preview();

// ---- Saved configs ----

function configPayload() {
  var d = formData();
  d.text = $('#labelText').val(); // save actual text (not replaced with space)
  d.clipart_icon = cachedClipartIcon || '';
  if (cachedClipartIcon) d.image_data = ''; // don't bloat config with rendered raster
  return d;
}

var savedConfigNames = [];

function formatSavedAt(s) {
  if (!s) return '';
  // Handle legacy "2026-03-05 06:35 UTC" and ISO "2026-03-05T06:35:12+00:00"
  var d = new Date(s.replace(' UTC', 'Z').replace(/(\d{4}-\d{2}-\d{2}) (\d{2}:\d{2})/, '$1T$2'));
  if (isNaN(d)) return s;
  var now = new Date();
  var diff = now - d;
  var mins  = Math.floor(diff / 60000);
  var hours = Math.floor(diff / 3600000);
  var days  = Math.floor(diff / 86400000);
  if (diff < 60000)  return 'just now';
  if (mins  < 60)    return mins + ' min ago';
  if (hours < 24)    return hours + ' hr ago';
  if (days  === 1)   return 'yesterday';
  if (days  < 7)     return days + ' days ago';
  var opts = { month: 'short', day: 'numeric' };
  if (d.getFullYear() !== now.getFullYear()) opts.year = 'numeric';
  return d.toLocaleDateString(undefined, opts);
}

function refreshConfigList() {
  $.getJSON('/api/configs', function(list) {
    savedConfigNames = list.map(function(c) { return c.name; });
    var $list = $('#configList').empty();
    if (!list.length) {
      $list.append('<div class="list-group-item text-body-secondary small px-0">No saved configs yet.</div>');
      return;
    }
    list.forEach(function(cfg) {
      var $item = $('<div class="list-group-item px-0 py-2" draggable="true">').attr('data-cfg-name', cfg.name);
      var $top = $('<div class="d-flex align-items-center gap-1 mb-1">').appendTo($item);
      $('<span class="text-body-secondary flex-shrink-0" style="cursor:grab;line-height:1">').html('<i class="bi bi-grip-vertical"></i>').appendTo($top);
      $('<span class="flex-grow-1 fw-medium text-truncate" style="min-width:0">').text(cfg.name).appendTo($top);
      var $btns = $('<div class="d-flex gap-1 flex-shrink-0">').appendTo($top);
      $('<button class="btn btn-sm btn-outline-primary" title="Save current settings to this config">')
        .html('<i class="bi bi-floppy"></i>')
        .on('click', function() { overwriteConfig(cfg.name); })
        .appendTo($btns);
      $('<button class="btn btn-sm btn-outline-secondary" title="Load">')
        .html('<i class="bi bi-upload"></i>')
        .on('click', function() { loadConfig(cfg.name); })
        .appendTo($btns);
      $('<button class="btn btn-sm btn-outline-secondary" title="Rename">')
        .html('<i class="bi bi-pencil"></i>')
        .on('click', function() { renameConfig(cfg.name); })
        .appendTo($btns);
      $('<button class="btn btn-sm btn-outline-secondary" title="Duplicate">')
        .html('<i class="bi bi-copy"></i>')
        .on('click', function() { duplicateConfig(cfg.name); })
        .appendTo($btns);
      $('<button class="btn btn-sm btn-outline-danger" title="Delete">')
        .html('<i class="bi bi-trash"></i>')
        .on('click', function() { deleteConfig(cfg.name, $item); })
        .appendTo($btns);
      if (cfg.saved_at) {
        $('<div class="text-body-secondary" style="font-size:0.72em">').text(formatSavedAt(cfg.saved_at)).appendTo($item);
      }
      $list.append($item);
    });

    // Drag-and-drop sort
    var dragSrc = null;
    $list.children('[draggable]').on('dragstart', function(e) {
      dragSrc = this;
      e.originalEvent.dataTransfer.effectAllowed = 'move';
      $(this).addClass('opacity-50');
    }).on('dragend', function() {
      $(this).removeClass('opacity-50');
      $list.children('[draggable]').removeClass('border-top border-primary');
    }).on('dragover', function(e) {
      e.preventDefault();
      if (!dragSrc || dragSrc === this) return;
      var items = $list.children('[draggable]').toArray();
      var fi = items.indexOf(dragSrc), ti = items.indexOf(this);
      if (fi < ti) $(this).after(dragSrc); else $(this).before(dragSrc);
    }).on('drop', function(e) {
      e.preventDefault();
      var order = $list.children('[draggable]').map(function() {
        return $(this).data('cfg-name');
      }).toArray();
      $.ajax({ type: 'PUT', url: '/api/configs/order', contentType: 'application/json', data: JSON.stringify(order) });
    });
  });
}

function saveConfig() {
  var name = $('#configName').val().trim();
  if (!name) { alert('Please enter a config name.'); return; }
  if (savedConfigNames.indexOf(name) !== -1) {
    if (!confirm('A config named "' + name + '" already exists. Replace it?')) return;
  }
  $.ajax({
    type: 'POST',
    url: '/api/configs/' + encodeURIComponent(name),
    contentType: 'application/json',
    data: JSON.stringify(configPayload()),
    success: function() { refreshConfigList(); },
    error: function() { alert('Failed to save config.'); }
  });
}

function overwriteConfig(name) {
  if (!confirm('Overwrite "' + name + '" with current settings?')) return;
  $.ajax({
    type: 'POST',
    url: '/api/configs/' + encodeURIComponent(name),
    contentType: 'application/json',
    data: JSON.stringify(configPayload()),
    success: function() { refreshConfigList(); },
    error: function() { alert('Failed to save config.'); }
  });
}

function duplicateConfig(name) {
  var n = 1;
  var newName;
  do { newName = name + ' (copy ' + n + ')'; n++; } while (savedConfigNames.indexOf(newName) !== -1);
  $.getJSON('/api/configs/' + encodeURIComponent(name), function(d) {
    $.ajax({
      type: 'POST',
      url: '/api/configs/' + encodeURIComponent(newName),
      contentType: 'application/json',
      data: JSON.stringify(d),
      success: function() { refreshConfigList(); },
      error: function() { alert('Failed to duplicate config.'); }
    });
  });
}

function renameConfig(name) {
  var newName = prompt('Rename "' + name + '" to:', name);
  if (!newName) return;
  newName = newName.trim();
  if (!newName || newName === name) return;
  if (savedConfigNames.indexOf(newName) !== -1) {
    if (!confirm('A config named "' + newName + '" already exists. Replace it?')) return;
  }
  $.getJSON('/api/configs/' + encodeURIComponent(name), function(d) {
    $.ajax({
      type: 'POST',
      url: '/api/configs/' + encodeURIComponent(newName),
      contentType: 'application/json',
      data: JSON.stringify(d),
      success: function() {
        $.ajax({
          type: 'DELETE',
          url: '/api/configs/' + encodeURIComponent(name),
          complete: function() {
            if ($('#configName').val() === name) $('#configName').val(newName);
            refreshConfigList();
          }
        });
      },
      error: function() { alert('Failed to rename config.'); }
    });
  });
}

function loadConfig(name) {
  $.getJSON('/api/configs/' + encodeURIComponent(name), function(d) {
    $('#configName').val(name);
    // Text
    $('#labelText').val(d.text || '');
    // Font
    $('#fontFamily option').filter(function() { return $(this).text() === d.font_family; }).prop('selected', true);
    $('#fontSize').val(d.font_size);
    // Alignment
    $('input[name=fontAlign][value="' + (d.align || 'center') + '"]').prop('checked', true);
    // Label size
    $('#labelSize').val(d.label_size);
    // Orientation
    // Margins
    $('#marginTop').val(d.margin_top);
    $('#marginBottom').val(d.margin_bottom);
    $('#marginLeft').val(d.margin_left);
    $('#marginRight').val(d.margin_right);
    // Border
    var borderOn = d.border === 'true' || d.border === true;
    $('#borderEnabled').prop('checked', borderOn);
    $('#borderWidthRow').toggle(borderOn);
    if (borderOn) $('#borderWidth').val(d.border_width);
    // Image / Clip art
    cachedClipartIcon = null;
    if (d.clipart_icon) {
      selectClipart(d.clipart_icon); // async; calls preview() on completion
    } else if (d.image_data) {
      cachedImageData = d.image_data;
      $('#imageOptions').show();
      $('#imageClearBtn').css('display', 'flex');
    } else {
      clearImage();
    }
    $('input[name=imageAlign][value="' + (d.image_align || 'left') + '"]').prop('checked', true);
    $('#imageGap').val(d.image_gap || 20);
    preview();
  });
}

function deleteConfig(name, $item) {
  if (!confirm('Delete config "' + name + '"?')) return;
  $.ajax({
    type: 'DELETE',
    url: '/api/configs/' + encodeURIComponent(name),
    success: function() { $item.remove(); if ($('#configList .list-group-item').length === 0) refreshConfigList(); },
    error: function() { alert('Failed to delete config.'); }
  });
}

function deleteAllConfigs() {
  if (!confirm('Delete ALL saved configs? This cannot be undone.')) return;
  $.ajax({
    type: 'DELETE',
    url: '/api/configs',
    success: function() { refreshConfigList(); },
    error: function() { alert('Failed to delete all configs.'); }
  });
}

refreshConfigList();
{% endblock %}
